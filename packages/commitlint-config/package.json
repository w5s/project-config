{
  "name": "@w5s/commitlint-config",
  "version": "3.0.7",
  "description": "Commitlint configuration presets",
  "keywords": [
    "commitlint",
    "git",
    "lint"
  ],
  "homepage": "https://github.com/w5s/project-config/blob/main/packages/commitlint-config#readme",
  "bugs": {
    "url": "https://github.com/w5s/project-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:w5s/project-config.git",
    "directory": "packages/commitlint-config"
  },
  "license": "MIT",
  "author": "Julien Polo <julien.polo@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./dist/*": "./dist/*"
  },
  "typings": "./index.d.mts",
  "files": [
    "dist/",
    "src/",
    "index.js",
    "index.d.ts",
    "!*.d.mts.map",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "scripts": {
    "build": "pnpm run \"/build:.*/\"",
    "build:tsc": "tsdown",
    "clean": "pnpm run \"/clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node ../../markdown.mjs",
    "format": "pnpm run \"/format:.*/\"",
    "format:src": "eslint . --fix",
    "lint": "pnpm run \"/lint:.*/\"",
    "lint:src": "eslint .",
    "postpack": "clean-package restore",
    "prepack": "clean-package",
    "prepublishOnly": "pnpm run clean;pnpm run build",
    "spellcheck": "cspell --no-progress '**'",
    "test": "pnpm run \"/test:.*/\"",
    "test:src": "vitest run"
  },
  "dependencies": {
    "@commitlint/types": "^20.0.0",
    "@w5s/conventional-changelog": "workspace:^"
  },
  "devDependencies": {
    "@commitlint/lint": "20.4.3",
    "@w5s/tsdown-config": "workspace:*",
    "tsdown": "0.20.3",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "@commitlint/cli": "^16.0.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^20.0.0"
  },
  "peerDependenciesMeta": {
    "@commitlint/cli": {
      "optional": true
    }
  },
  "clean-package": "../../clean-package.config.mjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffect": false
}
