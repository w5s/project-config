{
  "name": "@w5s/commitlint-config",
  "version": "3.1.17",
  "description": "Commitlint configuration presets",
  "keywords": [
    "commitlint",
    "git",
    "lint"
  ],
  "homepage": "https://github.com/w5s/project-config/blob/main/packages/commitlint-config#readme",
  "bugs": {
    "url": "https://github.com/w5s/project-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w5s/project-config.git",
    "directory": "packages/commitlint-config"
  },
  "license": "MIT",
  "author": "Julien Polo <julien.polo@gmail.com>",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js",
    "./internal/*": null
  },
  "files": [
    "dist/",
    "src/",
    "index.js",
    "index.d.ts",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "pnpm exec tsdown",
    "clean": "pnpm run \"/^clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node ../../markdown.mjs",
    "format": "pnpm run \"/^format:.*/\"",
    "format:src": "pnpm exec eslint . --fix",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:src": "pnpm exec eslint .",
    "postpack": "clean-package restore",
    "prepack": "clean-package",
    "prepublishOnly": "pnpm run clean;pnpm run build",
    "spellcheck": "pnpm exec cspell --no-progress '**'",
    "test": "pnpm run \"/^test:.*/\"",
    "test:src": "pnpm exec vitest run",
    "typecheck": "pnpm run \"/^typecheck:.*/\"",
    "typecheck:src": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "@commitlint/types": "^21.0.0",
    "@w5s/conventional-changelog": "workspace:^"
  },
  "devDependencies": {
    "@commitlint/lint": "21.2.0",
    "@w5s/tsdown-config": "workspace:*"
  },
  "peerDependencies": {
    "@commitlint/cli": "^16.0.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^20.0.0 || ^21.0.0"
  },
  "peerDependenciesMeta": {
    "@commitlint/cli": {
      "optional": true
    }
  },
  "clean-package": "../../clean-package.config.cjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffect": false
}
