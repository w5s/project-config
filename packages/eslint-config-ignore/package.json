{
  "name": "@w5s/eslint-config-ignore",
  "version": "1.2.8",
  "description": "Shared ESLint ignore configuration generator",
  "keywords": [
    "eslint",
    "config",
    "ignore"
  ],
  "homepage": "https://github.com/w5s/project-config/blob/main/packages/eslint-config-ignore#readme",
  "bugs": {
    "url": "https://github.com/w5s/project-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w5s/project-config.git",
    "directory": "packages/eslint-config-ignore"
  },
  "license": "MIT",
  "author": "Julien Polo <julien.polo@gmail.com>",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js",
    "./internal/*": null
  },
  "files": [
    "dist/",
    "src/",
    "index.js",
    "index.d.ts",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "pnpm exec tsdown",
    "clean": "pnpm run \"/^clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node ../../markdown.mjs",
    "format": "pnpm run \"/^format:.*/\"",
    "format:src": "pnpm exec eslint . --fix",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:src": "pnpm exec eslint .",
    "postpack": "clean-package restore",
    "prepack": "clean-package",
    "prepublishOnly": "pnpm run clean;pnpm run build",
    "spellcheck": "pnpm exec cspell --no-progress '**'",
    "test": "pnpm run \"/^test:.*/\"",
    "test:src": "pnpm exec vitest run",
    "typecheck": "pnpm run \"/^typecheck:.*/\"",
    "typecheck:src": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "find-up": "^8.0.0",
    "parse-gitignore": "^2.0.0"
  },
  "devDependencies": {
    "@w5s/tsdown-config": "workspace:*"
  },
  "peerDependencies": {
    "eslint": "9.x || 10.x",
    "typescript": "4.x || 5.x || 6.x"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "clean-package": "../../clean-package.config.cjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffect": false
}
