{
  "name": "@w5s/pnpm-plugin-config",
  "version": "1.0.0-alpha.2",
  "description": "Shared pnpm configuration plugin with org defaults",
  "keywords": [
    "pnpm",
    "pnpm-config",
    "config"
  ],
  "homepage": "https://github.com/w5s/project-config/blob/main/packages/pnpm-plugin-config#readme",
  "bugs": {
    "url": "https://github.com/w5s/project-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:w5s/project-config.git",
    "directory": "packages/pnpm-plugin-config"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js",
    "./pnpmfile.mjs": "./pnpmfile.mjs",
    "./internal/*": null
  },
  "files": [
    "dist/",
    "pnpmfile.mjs",
    "src/",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "tsdown",
    "clean": "pnpm run \"/^clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node ../../markdown.mjs",
    "format": "pnpm run \"/^format:.*/\"",
    "format:src": "eslint . --fix",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:src": "eslint .",
    "postpack": "clean-package restore",
    "prepack": "clean-package",
    "prepublishOnly": "pnpm run clean;pnpm run build",
    "spellcheck": "cspell --no-progress '**'",
    "test": "pnpm run \"/^test:.*/\"",
    "test:src": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@pnpm/config": "1004.11.0",
    "@w5s/tsdown-config": "workspace:*"
  },
  "clean-package": "../../clean-package.config.cjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffect": false
}
