#!/bin/sh
cd $(dirname $(dirname "$0"))
ROOT=$(pwd)

set -e;

eslint ()
{
  pnpm exec eslint "$@";
}

test_project ()
{
  PROJECT_NAME=$1
  echo "Test $PROJECT_NAME"
  cd "test/$PROJECT_NAME";

  shift;
  eslint . "$@";
  cd "$ROOT";
}

for dir in test/*/; do
  if [ -d "$dir" ]; then
    test_project "$(basename "$dir")";
  fi
done
