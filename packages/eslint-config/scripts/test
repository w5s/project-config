#!/bin/sh
cd $(dirname $(dirname "$0"))
ROOT=$(pwd)

set -e;

eslint ()
{
  pnpm exec eslint "$@";
}

test_project ()
{
  PROJECT_NAME=$1
  echo "Test $PROJECT_NAME"
  cd "_tests/$PROJECT_NAME";

  shift;
  eslint . "$@";
  cd "$ROOT";
}

test_project es-project;
test_project ts-project;
test_project json;
