{
  "name": "@w5s/cspell-config",
  "version": "3.1.15",
  "description": "CSpell configuration presets",
  "keywords": [
    "cspell"
  ],
  "homepage": "https://github.com/w5s/project-config/blob/main/packages/cspell-config#readme",
  "bugs": {
    "url": "https://github.com/w5s/project-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w5s/project-config.git",
    "directory": "packages/cspell-config"
  },
  "license": "MIT",
  "author": "Julien Polo <julien.polo@gmail.com>",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./cspell-ext.json",
    "./cspell-ext.json": "./cspell-ext.json",
    "./internal/*": null,
    "./dict/*": "./dict/*"
  },
  "files": [
    "cspell-ext.json",
    "dict/",
    "dist/",
    "src/",
    "index.js",
    "index.d.ts",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "scripts": {
    "__build:dict": "cd dict;cspell-tools-cli compile filetypes.txt",
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "tsdown",
    "clean": "pnpm run \"/^clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node ../../markdown.mjs",
    "format": "pnpm run \"/^format:.*/\"",
    "format:src": "eslint . --fix",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:src": "eslint .",
    "postpack": "clean-package restore",
    "prepack": "clean-package",
    "prepublishOnly": "pnpm run clean;pnpm run build",
    "spellcheck": "cspell --no-progress '**'",
    "test": "pnpm run \"/^test:.*/\"",
    "test:src": "vitest run",
    "typecheck": "pnpm run \"/^typecheck:.*/\"",
    "typecheck:src": "tsc --noEmit"
  },
  "dependencies": {
    "@cspell/cspell-bundled-dicts": "^10.0.0"
  },
  "devDependencies": {
    "@cspell/cspell-bundled-dicts": "10.0.1",
    "@cspell/cspell-tools": "10.0.1",
    "@cspell/cspell-types": "10.0.1",
    "@w5s/tsdown-config": "workspace:*",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "cspell": "^6.0.0 || ^7.0.0 || ^8.0.0 || ^9.0.0 || ^10.0.0"
  },
  "peerDependenciesMeta": {
    "cspell": {
      "optional": true
    }
  },
  "clean-package": "../../clean-package.config.cjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffect": false
}
