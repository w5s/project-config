{
  "name": "@w5s/browserslist-config",
  "version": "3.1.21",
  "description": "Browserslist support shared configuration",
  "keywords": [
    "browserslist",
    "config"
  ],
  "homepage": "https://github.com/w5s/project-config/blob/master/packages/browserslist-config#readme",
  "bugs": {
    "url": "https://github.com/w5s/project-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w5s/project-config.git",
    "directory": "packages/browserslist-config"
  },
  "license": "MIT",
  "author": "Julien Polo <julien.polo@gmail.com>",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./*": {
      "require": "./dist/*.cjs",
      "import": "./dist/*.js"
    },
    "./internal/*": null
  },
  "files": [
    "dist/",
    "src/",
    "index.js",
    "index.d.ts",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "pnpm exec tsdown",
    "clean": "pnpm run \"/^clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node scripts/build-docs.mjs && node ../../markdown.mjs && (git commit 'README.md' 'BROWSER_LIST.md' -m '📝 Update browserslist support') || true",
    "format": "pnpm run \"/^format:.*/\"",
    "format:src": "pnpm exec eslint . --fix",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:src": "pnpm exec eslint .",
    "postpack": "clean-package restore",
    "prepack": "clean-package",
    "prepublishOnly": "pnpm run clean;pnpm run build",
    "spellcheck": "pnpm exec cspell --no-progress '**'",
    "test": "pnpm run \"/^test:.*/\"",
    "test:src": "pnpm exec vitest run",
    "typecheck": "pnpm run \"/^typecheck:.*/\"",
    "typecheck:src": "pnpm exec tsc --noEmit"
  },
  "devDependencies": {
    "@w5s/tsdown-config": "workspace:*",
    "browserslist": "4.28.6",
    "lodash-es": "4.18.1"
  },
  "peerDependencies": {
    "browserslist": ">= 4.0"
  },
  "peerDependenciesMeta": {
    "browserslist": {
      "optional": true
    }
  },
  "clean-package": "../../clean-package.config.cjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffect": false
}
