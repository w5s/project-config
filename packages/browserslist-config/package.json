{
  "name": "@w5s/browserslist-config",
  "version": "3.1.7",
  "description": "Browserslist support shared configuration",
  "keywords": [
    "browserslist",
    "config"
  ],
  "homepage": "https://github.com/w5s/project-config/blob/master/packages/browserslist-config#readme",
  "bugs": {
    "url": "https://github.com/w5s/project-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:w5s/project-config.git",
    "directory": "packages/browserslist-config"
  },
  "license": "MIT",
  "author": "Julien Polo <julien.polo@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./*": {
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      },
      "import": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      }
    },
    "./dist/*": "./dist/*"
  },
  "typings": "./index.d.ts",
  "files": [
    "dist/",
    "src/",
    "index.js",
    "index.d.ts",
    "!*.d.ts.map",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "tsdown",
    "clean": "pnpm run \"/^clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node scripts/build-docs.mjs && node ../../markdown.mjs && (git commit 'README.md' 'BROWSER_LIST.md' -m '📝 Update browserslist support') || true",
    "format": "pnpm run \"/^format:.*/\"",
    "format:src": "eslint . --fix",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:src": "eslint .",
    "postpack": "clean-package restore",
    "prepack": "clean-package",
    "prepublishOnly": "pnpm run clean;pnpm run build",
    "spellcheck": "cspell --no-progress '**'",
    "test": "pnpm run \"/^test:.*/\"",
    "test:src": "vitest run"
  },
  "devDependencies": {
    "@w5s/tsdown-config": "workspace:*",
    "browserslist": "4.28.2",
    "lodash-es": "4.18.1",
    "tsdown": "0.21.8",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "browserslist": ">= 4.0"
  },
  "peerDependenciesMeta": {
    "browserslist": {
      "optional": true
    }
  },
  "clean-package": "../../clean-package.config.cjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffect": false
}
