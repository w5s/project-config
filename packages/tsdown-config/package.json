{
  "name": "@w5s/tsdown-config",
  "version": "1.0.0-alpha.8",
  "description": "Shared tsdown configuration",
  "keywords": [
    "typescript",
    "config",
    "tsc",
    "tsdown"
  ],
  "homepage": "https://github.com/w5s/project-config/blob/main/packages/tsdown-config#readme",
  "bugs": {
    "url": "https://github.com/w5s/project-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh@github.com:w5s/project-config.git",
    "directory": "packages/tsdown-config"
  },
  "license": "MIT",
  "author": "Julien Polo <julien.polo@gmail.com>",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null
  },
  "files": [
    "dist/",
    "src/",
    "index.js",
    "index.d.ts",
    "!*.d.ts.map",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "tsdown",
    "clean": "pnpm run \"/^clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node ../../markdown.mjs",
    "format": "pnpm run \"/^format:.*/\"",
    "format:src": "eslint . --fix",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:src": "eslint .",
    "postpack": "clean-package restore",
    "prepack": "clean-package",
    "prepublishOnly": "pnpm run clean;pnpm run build",
    "spellcheck": "cspell --no-progress '**'",
    "test": "pnpm run \"/^test:.*/\"",
    "test:src": "vitest run",
    "typecheck": "pnpm run \"/^typecheck:.*/\"",
    "typecheck:src": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "0.22.2",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "tsdown": "0.x"
  },
  "peerDependenciesMeta": {
    "tsdown": {
      "optional": true
    }
  },
  "clean-package": "../../clean-package.config.cjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  },
  "sideEffect": false
}
