{
  "name": "@w5s/tsdown-config",
  "version": "1.0.0-alpha.4",
  "description": "Shared tsdown configuration",
  "keywords": [
    "typescript",
    "config",
    "tsc",
    "tsdown"
  ],
  "homepage": "https://github.com/w5s/project-config/blob/main/packages/tsdown-config#readme",
  "bugs": {
    "url": "https://github.com/w5s/project-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:w5s/project-config.git",
    "directory": "packages/tsdown-config"
  },
  "license": "MIT",
  "author": "Julien Polo <julien.polo@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist/",
    "src/",
    "index.js",
    "index.d.ts",
    "!*.d.ts.map",
    "!**/*.spec.*",
    "!**/__tests__/**"
  ],
  "tsdown": {
    "entry": [
      "src/index.ts"
    ],
    "sourcemap": true,
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true
  },
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "tsc -b tsconfig.build.json",
    "clean": "pnpm run \"/^clean:.*/\"",
    "clean:tsc": "rm -rf dist",
    "docs": "node ../../markdown.mjs",
    "format": "pnpm run \"/^format:.*/\"",
    "format:src": "eslint . --fix",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:src": "eslint .",
    "postpack": "clean-package restore",
    "prepack": "clean-package",
    "prepublishOnly": "pnpm run clean;pnpm run build",
    "spellcheck": "cspell --no-progress '**'",
    "test": "pnpm run \"/^test:.*/\"",
    "test:src": "vitest run"
  },
  "devDependencies": {
    "tsdown": "0.21.9",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "tsdown": "0.x"
  },
  "peerDependenciesMeta": {
    "tsdown": {
      "optional": true
    }
  },
  "clean-package": "../../clean-package.config.cjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffect": false
}
